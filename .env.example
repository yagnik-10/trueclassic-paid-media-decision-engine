# Environment configuration (copy to .env). The engine itself needs NONE of
# these — generation is fully offline & deterministic. They are placeholders for
# the API and later stages so the contract is visible up front.

# Determinism (the synthetic-data generator)
DECISION_ENGINE_MASTER_SEED=20240117

# Backend API (Stage 1). The Makefile reads API_HOST / API_PORT for `make api`.
API_HOST=127.0.0.1
API_PORT=8000

# Frontend (Stage 1). The Next.js app reads NEXT_PUBLIC_API_BASE to reach the API
# (defaults to http://localhost:8000 when unset).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# LLM sidecar (Stage 5) — bounded ranking/narration only, never numeric decisions.
# Every LLM feature has a deterministic template fallback, so this can be empty.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Platform ingestion (Stage 2) — STUBBED in this prototype. No real OAuth,
# no live media writes. Left blank intentionally.
META_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
SHOPIFY_ADMIN_TOKEN=
