# TrueNorth environment configuration (copy to .env)
# Stage 0 needs NONE of these to run — generation is fully offline & deterministic.
# They are placeholders for later stages so the contract is visible up front.

# Determinism (Stage 0)
TRUENORTH_MASTER_SEED=20240117

# LLM sidecar (Stage 5) — bounded ranking/narration only, never numeric decisions.
# Every LLM feature has a deterministic template fallback, so this can be empty.
ANTHROPIC_API_KEY=
TRUENORTH_LLM_MODEL=claude-sonnet-4-6

# Platform ingestion (Stage 2) — STUBBED in this prototype. No real OAuth,
# no live media writes. Left blank intentionally.
META_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
SHOPIFY_ADMIN_TOKEN=

# Backend (Stage 1)
TRUENORTH_API_HOST=127.0.0.1
TRUENORTH_API_PORT=8000
