# Python
__pycache__/
*.py[cod]
.venv/
.venv-verify/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Env
.env

# Generated data artifacts (regenerate with `make generate`)
data/canonical/*
data/raw/*
!data/canonical/.gitkeep
!data/raw/.gitkeep

# Internal latent generator truth — NEVER committed (debug/test opt-in only)
data/internal/

# Realistic profile (D-034): regenerate with `make generate-realistic`. Its
# fingerprint is pinned in tests; the bytes are reproducible so not committed.
data/realistic/

# Durable append-only audit store (Stage 4.4) — runtime decision log (sqlite)
data/audit/

# Model-performance report (reproducible via `make model-report`) — tracked so the
# plots/metrics are visible in the editor and reviewable in git.

# Node / frontend (Stage 1)
node_modules/
.next/

# OS
.DS_Store
